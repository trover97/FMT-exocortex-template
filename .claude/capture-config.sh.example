#!/bin/bash
# capture-config.sh.example — шаблон пользовательской конфигурации capture_writer.sh.
#
# Чтобы активировать: скопируйте в `.claude/capture-config.sh` (без `.example`)
# и адаптируйте под свою структуру репо. Файл вне FMT-обновлений (update.sh не
# трогает) — это локальный override.
#
# Поведение по умолчанию (без файла):
#   agent_incident → пишется в `<target_repo>/inbox/incident-log-YYYY-MM.md`,
#   где target_repo определяется детектором (HD «Лог рядом с исполнителем»,
#   DP.D.049). Это значит инциденты разбросаны по тем репо, где случились.
#
# Зачем override: если у вас есть отдельный governance-репо для агрегации
# инцидентов (мониторинг паттернов, ретроспективы), задайте путь — и все
# agent_incident потекут туда.

# Пример: агрегация в собственный governance-репо (адаптируйте путь).
# export INCIDENT_TARGET_REPO="${IWE_ROOT:-$HOME/IWE}/<your-governance-repo>"
# export INCIDENT_REL_DIR="incidents"
